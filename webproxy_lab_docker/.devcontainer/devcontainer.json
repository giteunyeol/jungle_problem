{
  "name": "Proxylab Development Container",
  "dockerFile": "Dockerfile",
  "remoteUser": "jungle",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces/jungle_problem,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/jungle_problem/webproxy_lab_docker",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpptools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.includePath": [
          "/usr/include",
          "/usr/local/include"
        ],
        "C_Cpp.default.compilerPath": "/usr/bin/gcc",
        "git.openRepositoryInParentFolders": "always"
      }
    }
  }
}
